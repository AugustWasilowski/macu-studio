# MACU pipeline machine config.
#
# Copy to `.env` on a NEW machine (e.g. Leo) and adjust the storage root. On Max,
# leave NO `.env` here — every value defaults to the current Max literal, so Max
# runs identically with no .env present. `.env` is gitignored; this file is tracked.
#
# Loaded by studio/backend/macu_studio/config.py and pipeline/lib.py (python-dotenv).
# python-dotenv does NOT override vars already set in the environment, so systemd
# Environment=/EnvironmentFile= lines still win.

# ---- Storage root — usually the ONLY thing you change per machine ----
MACU_SHARES=/mnt/storage/shares/MACU
# Derived from MACU_SHARES by default; override only if these live off that tree:
# MACU_EPISODES=/mnt/storage/shares/MACU/episodes
# MACU_ASSETS=/mnt/storage/shares/MACU/assets
# MACU_PIPELINE=/mnt/storage/shares/MACU/pipeline

# ---- ComfyUI output (where the render server picks up webps) ----
MACU_COMFY_OUT=/mnt/storage/comfyui/output/macu
MACU_COMFY_OUTPUT_ROOT=/mnt/storage/comfyui/output

# ---- audio-gen (agen) CLI location ----
MACU_AGEN=/mnt/storage/audio-gen/agen

# ---- Local service endpoints (loopback; change only if a service is remote) ----
# MACU_COMFY_URL=http://127.0.0.1:8188
# MACU_PIPER_URL=http://127.0.0.1:5050
# MACU_OMNIVOICE_URL=http://127.0.0.1:3900
# MACU_OMNIVOICE_CONTAINER=omnivoice
# MACU_RENDER_URL=http://127.0.0.1:8773

# ---- Studio bind ----
# MACU_STUDIO_HOST=0.0.0.0
# MACU_STUDIO_PORT=8774

# ---- Misc ----
# MACU_STORAGE_MOUNT=/mnt/storage          # disk-usage widget mount (cosmetic)
# MACU_REPO_ROOT=/mnt/storage/macu-pipeline # used by systemd units / installer (later phase)

# ---- Secrets / integrations (optional; prefer ~/.claude/... and ~/.config/... files) ----
# SS_CHAT_WEBHOOK_TOKEN=
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=
