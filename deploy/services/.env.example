# Docker-volume config for the MACU GPU services (OmniVoice / Ollama / ComfyUI).
# Copy to `.env` and adjust on a new machine. On Max, the compose defaults already
# resolve to /mnt/storage, so no .env is needed there.
#
# Use it with each service:  docker compose --env-file ../.env -f docker-compose.yml up -d
# (or just `export MACU_DATA_ROOT=...` before running compose).

# Root that holds the services' persistent data (models, state, ComfyUI source).
# Each service uses ${MACU_DATA_ROOT}/{omnivoice,ollama,comfyui}/...
MACU_DATA_ROOT=/mnt/storage

# Timezone stamped into OmniVoice/ComfyUI.
TZ=America/Chicago
