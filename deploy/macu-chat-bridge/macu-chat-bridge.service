# systemd --user unit for the MACU chat bridge. The setup skill substitutes __REPO__
# (the repo path) and __CLAUDE_BIN__ (the ABSOLUTE path to `claude`) and installs this
# to ~/.config/systemd/user/, then `systemctl --user enable --now macu-chat-bridge`.
# (On WSL / no user-systemd, the skill falls back to launching bridge.py under nohup.)
#
# Why MACU_CLAUDE_BIN: systemd --user has a minimal PATH that usually omits
# ~/.local/bin (where `claude` often lives), so the bridge's default `claude` wouldn't
# resolve. The skill pins the absolute path here.
[Unit]
Description=MACU chat bridge (Studio chat tile <-> Claude Code via claude -p)
After=default.target

[Service]
Type=simple
ExecStart=/usr/bin/env python3 __REPO__/deploy/macu-chat-bridge/bridge.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1
Environment=MACU_CLAUDE_BIN=__CLAUDE_BIN__

[Install]
WantedBy=default.target
