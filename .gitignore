__pycache__/
*.pyc
*.pyo
.venv/
venv/
.whisper-venv/
.env
.env.*
**/.env
!*.env.example
.DS_Store
*.log
.idea/
.vscode/

# Episode artifacts (large generated files)
episodes/*/clips/
episodes/*/vo/
episodes/*/frames/
episodes/*/final/
episodes/*/.rife_frames/
episodes/*/.work/
episodes/*/titles/*.mp4
# Assets (large binary files)
assets/music/
assets/sfx/
assets/fonts/
# Voice profiles
voices/*.wav
voices/*.mp3
# ComfyUI outputs
*.webp
*.zs.webp
# Whisper cache
/tmp/
# Episode backup dirs
*backup*/
# Legacy episode dirs (EP2/EP3/EP4 were pre-pipeline)
EP2/
EP3/
EP4/
Commercials/

# Per-install content — the author's shows + per-show creative canon. A clone ships
# none of these; they're created at runtime (shows.json seeds a neutral starter show;
# docs/shows/<id>/ is scaffolded from docs/_templates/show/ on show creation).
studio/shows.json
docs/shows/

# studio
studio/frontend/node_modules/
studio/frontend/dist/
studio/frontend/tsconfig.tsbuildinfo
studio/**/*.egg-info/

# Timestamped manifest backups (created by in-place edits)
*.bak.*
*.json.bak.*
studio/frontend/pnpm-lock.yaml

# Author-private design notes (agent topology / infra) — kept locally, not shipped
docs/_common/MACU_Pipeline_Design.md
